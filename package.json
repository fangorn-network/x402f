{
  "name": "x402f",
  "version": "0.0.1",
  "description": "x402 + Fangorn",
  "private": true,
  "type": "module",
  "workspaces": [
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "client:node": "npx tsx --env-file=./examples/node/.env examples/node/index.ts",
    "server": "npx tsx --env-file=./packages/server/.env packages/server/src/index.ts",
    "facilitator": "npx tsx --env-file=./packages/facilitator/.env packages/facilitator/src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsdown",
    "publish:all": "pnpm --filter './packages/*' publish --access public"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsdown": "0.16.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fangorn-network/x402f.git"
  },
  "bugs": {
    "url": "https://github.com/fangorn-network/x402f/issues"
  },
  "homepage": "https://github.com/fangorn-network/x402f#readme",
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e16f04a"
}