{
  "name": "x402f",
  "version": "1.0.0",
  "description": "First setup environment variables by running `cp .env.local .env` and filling in the details.",
  "main": "lib/index.js",
  "type": "module",
  "files": [
    "lib/"
  ],
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ESNext"
    ],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*"
  ],
  "scripts": {
    "server": "npx tsx --env-file=.env src/server/index.ts",
    "client:node": "npx tsx --env-file=.env examples/node/index.ts",
    "client:agent": "npx tsx --env-file=.env examples/agent/index.ts",
    "facilitator": "npx tsx --env-file=.env src/facilitator/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsdown"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@lit-protocol/access-control-conditions": "^8.0.2",
    "@lit-protocol/lit-client": "^8.3.1",
    "@lit-protocol/networks": "^8.4.1",
    "@x402/core": "^2.3.0",
    "@x402/evm": "^2.3.0",
    "@x402/express": "^2.3.0",
    "@x402/fetch": "^2.3.0",
    "@x402/next": "^2.3.0",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fangorn-sdk": "^0.0.5",
    "fetch": "^1.1.0",
    "pinata": "^2.5.3",
    "signer": "link:@x402/evm/signer",
    "types": "link:@x402/evm/types",
    "viem": "^2.45.0",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "tsdown": "0.16.8"
  },
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fangorn-network/x402f.git"
  },
  "bugs": {
    "url": "https://github.com/fangorn-network/x402f/issues"
  },
  "homepage": "https://github.com/fangorn-network/x402f#readme",
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}